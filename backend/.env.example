# Copy to .env and fill in values (never commit .env)

# Gmail / Google Workspace SMTP (same for @gmail.com and custom domains like @keepmesafe.live)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=michael.grisales@keepmesafe.live
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=michael.grisales@keepmesafe.live

# Where contact form notifications go (usually same as above)
CONTACT_RECEIVER_EMAIL=michael.grisales@keepmesafe.live
